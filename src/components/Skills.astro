---
// Load every logo in src/images so filenames resolve through one lookup.
const images = import.meta.glob('../images/*.{png,jpg,jpeg,webp}', { eager: true });
const logoSrc = (file: string) =>
  (images[`../images/${file}`] as any)?.default?.src;

const skillCategories = [
  {
    name: "Languages",
    skills: [
      { name: "Python", file: "python.png" },
      { name: "C", file: "c-programming.png" },
      { name: "C++", file: "cpp.png" },
      { name: "C#", file: "csharp.png" },
      { name: "Rust", file: "rust.png" },
      { name: "Java", file: "java.png" },
      { name: "HTML", file: "html.png" },
      { name: "CSS", file: "css.png" },
      { name: "JavaScript", file: "javascript.png" },
      { name: "TypeScript", file: "typescript.png" },
      { name: "SQL", file: "sql.png" },
    ],
  },
  {
    name: "Frameworks",
    skills: [
      { name: "Flask", file: "flask.jpeg" },
      { name: "Node.js", file: "nodejs.png" },
      { name: "Next.js", file: "nextjs.png" },
      { name: "Astro.js", file: "astro.png" },
      { name: "React.js", file: "react.png" },
      { name: "React Native", file: "react.png" },
      { name: "TailwindCSS", file: "tailwind.png" },
    ],
  },
  {
    name: "Libraries",
    skills: [
      { name: "PyTorch", file: "pytorch.png" },
      { name: "TensorFlow", file: "tensorflow.png" },
      { name: "Pandas", file: "pandas.png" },
      { name: "NumPy", file: "numpy.png" },
      { name: "Optuna", file: "optuna.png" },
      { name: "SciPy", file: "scipy.png" },
      { name: "LangChain", file: "langchain.png" },
      { name: "Matplotlib", file: "matplotlib.png" },
      { name: "Plotly", file: "plotly.png" },
    ],
  },
  {
    name: "Tools & Platforms",
    skills: [
      { name: "Git", file: "git.png" },
      { name: "SQLite", file: "sqlite.png" },
      { name: "Docker", file: "docker.webp" },
      { name: "Kubernetes", file: "kubernetes.png" },
      { name: "AWS", file: "aws.png" },
      { name: "PostgreSQL", file: "postgres.png" },
      { name: "Microsoft SQL Server", file: "microsoftsqlserver.png" },
      { name: "Terraform", file: "terraform.png" },
    ],
  },
];
---

<section class="skills" id="skills">
  <div class="container">
    <div class="section-header reveal">
      <div class="section-eyebrow">
        <span class="section-eyebrow-line"></span>
        <span class="section-eyebrow-text">Technical Expertise</span>
      </div>
      <h2 class="section-title">
        Skills & <span class="text-gradient">Technologies</span>
      </h2>
      <p class="section-description">
        Languages, frameworks, and tools I use to build
        scalable applications and machine learning systems.
      </p>
    </div>

    <div class="skills-grid">
      {skillCategories.map((category, index) => (
        <div class={`skill-category reveal reveal-delay-${(index % 3) + 1}`}>
          <h3 class="category-title">{category.name}</h3>
          <div class="skill-list">
            {category.skills.map((skill) => (
              <div class="skill">
                <div class="skill-logo">
                  <img src={logoSrc(skill.file)} alt={skill.name} loading="lazy" />
                </div>
                <span class="skill-name">{skill.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skills {
    position: relative;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    margin-top: 3rem;
  }

  .skill-category {
    padding: 1.75rem;
    background: var(--bg-card);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    transition: border-color 0.3s, transform 0.4s var(--ease-out-expo);
  }

  .skill-category:hover {
    border-color: var(--accent-amber);
    transform: translateY(-4px);
  }

  .category-title {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent-amber);
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border-default);
  }

  .skill-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(74px, 1fr));
    gap: 1.5rem 1rem;
  }

  .skill {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    text-align: center;
  }

  .skill-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    padding: 11px;
    background: #ffffff;
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    transition: transform 0.25s var(--ease-spring),
                box-shadow 0.25s var(--ease-out-expo);
  }

  /* Fill the tile uniformly, preserving each logo's aspect ratio */
  .skill-logo img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .skill-logo:hover {
    transform: scale(1.12);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.35);
  }

  .skill-name {
    font-size: 0.75rem;
    color: var(--text-secondary);
    line-height: 1.3;
  }

  @media (max-width: 800px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
