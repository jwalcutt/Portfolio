    width: 16px;
    height: 16px;
    transition: transform 0.3s;
  }
  
  .project-link:hover svg {
    transform: translate(4px, -4px);
  }
  
  /* GitHub CTA */
  .projects-cta {
    margin-top: 4rem;
    text-align: center;
  }
  
  .github-link {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.5rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text-secondary);
    background: var(--bg-card);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    transition: all 0.3s;
  }
  
  .github-link:hover {
    color: var(--text-primary);
    border-color: var(--accent-amber);
    transform: translateY(-2px);
  }
  
  .github-link svg {
    width: 20px;
    height: 20px;
  }
  
  .github-link .arrow {
    transition: transform 0.3s;
  }
  
  .github-link:hover .arrow {
    transform: translateX(4px);
  }
  
  /* Project detail modal */
  .project-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }

  .project-modal[hidden] {
    display: none;
  }

  .project-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(1, 4, 9, 0.75);
    backdrop-filter: blur(4px);
    animation: modal-fade 0.25s var(--ease-out-expo);
  }

  .project-modal-dialog {
    position: relative;
    width: min(720px, 100%);
    max-height: 88vh;
    overflow-y: auto;
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    box-shadow: 0 24px 80px rgba(1, 4, 9, 0.6);
    animation: modal-rise 0.35s var(--ease-out-expo);
  }

  @keyframes modal-fade {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes modal-rise {
    from { opacity: 0; transform: translateY(16px) scale(0.98); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  .project-modal-x {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: var(--text-secondary);
    background: var(--bg-card);
