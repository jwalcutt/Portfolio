---
import nventLogo from '../images/nvent.jpg';
import vnLogo from '../images/vnservices.jpg';

const experiences = [
  {
    role: "Software Engineering Co-op",
    company: "nVent",
    logo: nventLogo.src,
    period: "May 2025 - December 2025",
    location: "Solon, OH",
    achievements: [
      "Trained and tested a Convolutional Autoencoder with PyTorch to detect anomalous activity in electrical waveforms, achieving a 93% detection rate on real datasets containing electrical arcs",
      "Engineered an anomaly scoring and thresholding pipeline using reconstruction error in Python, reducing false positives by 95% across all test cases",
      "Ran Bayesian hyperparameter optimization with Optuna, significantly cutting experimentation time and achieving a high-performance model with fewer training runs",
      "Parsed Node.js server logs and designed a dashboard using React.js and TailwindCSS to track test outcomes, improving testing and documentation efficiency",
      "Maintained a Jira automation tool tracking 1000+ projects, saving the company $100k+ in annual labor costs",
    ],
    technologies: ["Python", "PyTorch", "Pandas", "React.js", "TailwindCSS", "JavaScript", "Excel", "Jira", "Optuna"]
  },
  {
    role: "Software Development Intern",
    company: "VN Services",
    logo: vnLogo.src,
    period: "June 2024 - December 2024",
    location: "Chesterland, OH",
    achievements: [
      "Designed and implemented a full-stack web application using Next.js and Flask capable of securely hosting and querying relational databases stored with SQLite",
      "Containerized the application with Docker and deployed to AWS Fargate (ECS), configuring task definitions, networking, and environment variables to enable cloud-based data hosting",
      "Implemented REST API endpoints supporting role-based authentication, CRUD operations, and input validation, improving app security and enforcing consistent API contracts",
      "Improved the backend features of an internal training platform, implementing server-side changes to support dynamic content delivery and an interactive user experience",
      "Orchestrated an automation workflow that periodically synchronized database updates with existing visualizations, improving the consistency of observed metrics"
    ],
    technologies: ["Python", "Next.js", "Flask", "SQLite", "HTML", "CSS", "JavaScript", "Docker", "AWS Fargate"]
  }
];

---

<section class="experience" id="experience">
  <div class="container">
    <div class="experience-content">
      <div class="section-header reveal">
        <div class="section-eyebrow">
          <span class="section-eyebrow-line"></span>
          <span class="section-eyebrow-text">Career</span>
        </div>
        <h2 class="section-title">
          Professional <span class="text-gradient">Experience</span>
        </h2>
      </div>

      <div class="timeline">
        {experiences.map((exp, index) => (
          <div class={`timeline-item reveal reveal-delay-${index + 1}`}>
            <div class="timeline-marker">
              <div class="timeline-dot"></div>
              <div class="timeline-line"></div>
            </div>

            <div class="timeline-content">
              <div class="timeline-header">
                <div class="timeline-role-info">
                  <h3 class="timeline-role">{exp.role}</h3>
                  <span class="timeline-company">{exp.company}</span>
                </div>
                <div class="timeline-meta">
                  <span class="timeline-period">{exp.period}</span>
                  <span class="timeline-location">{exp.location}</span>
                </div>
              </div>
              <ul class="timeline-achievements">
                {exp.achievements.map(achievement => (
                  <li>{achievement}</li>
                ))}
              </ul>

              <div class="timeline-tech">
                {exp.technologies.map(tech => (
                  <span class="timeline-tech-item">{tech}</span>
                ))}
              </div>
            </div>

            <div class="timeline-logo">
              <img src={exp.logo} alt={`${exp.company} logo`} loading="lazy" />
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .experience {
    position: relative;
  }

  .experience-content {
    max-width: 960px;
  }

  /* Timeline */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  
  .timeline-item {
    display: grid;
    grid-template-columns: 24px 1fr 180px;
    gap: 1.5rem;
  }
  
  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  
  .timeline-dot {
    width: 12px;
    height: 12px;
    background: var(--accent-amber);
    border-radius: 50%;
    flex-shrink: 0;
    box-shadow: 0 0 0 4px var(--accent-amber-dim);
  }
  
  .timeline-line {
    width: 2px;
    flex: 1;
    background: var(--border-default);
    margin-top: 0.5rem;
  }
  
  .timeline-item:last-child .timeline-line {
    display: none;
  }
  
  .timeline-content {
    padding-bottom: 3rem;
  }

  .timeline-item:last-child .timeline-content {
    padding-bottom: 0;
  }

  /* Company logo: own column, top-aligned, spanning header to ~first bullet */
  .timeline-logo {
    align-self: start;
    display: flex;
    justify-content: center;
  }

  .timeline-logo img {
    display: block;
    max-height: 7.5rem;
    max-width: 100%;
    width: auto;
    height: auto;
    border: 1px solid var(--border-default);
    border-radius: var(--radius-sm);
  }

  .timeline-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  
  .timeline-role {
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }
  
  .timeline-company {
    font-size: 1rem;
    color: var(--accent-amber);
  }
  
  .timeline-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.125rem;
    flex-shrink: 0;
  }
  
  .timeline-period {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-secondary);
  }
  
  .timeline-location {
    font-size: 0.8125rem;
    color: var(--text-muted);
  }
  
  .timeline-achievements {
    list-style: none;
    margin-bottom: 1rem;
  }
  
  .timeline-achievements li {
    position: relative;
    padding-left: 1.25rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }
  
  .timeline-achievements li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 6px;
    height: 6px;
    background: var(--accent-amber);
    border-radius: 50%;
  }
  
  .timeline-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  
  .timeline-tech-item {
    padding: 0.25rem 0.625rem;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--text-muted);
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-sm);
  }
  
  @media (max-width: 768px) {
    .timeline-item {
      grid-template-columns: 24px 1fr 120px;
      gap: 1rem;
    }

    .timeline-logo img {
      max-height: 5rem;
    }
  }

  @media (max-width: 600px) {
    .timeline-item {
      grid-template-columns: 20px 1fr;
    }

    .timeline-header {
      flex-direction: column;
      gap: 0.5rem;
    }

    .timeline-meta {
      align-items: flex-start;
    }

    /* Logo moves under the text, left-aligned */
    .timeline-logo {
      grid-column: 2;
      justify-content: flex-start;
      margin-bottom: 1.5rem;
    }

    .timeline-logo img {
      max-height: 4rem;
    }
  }
</style>
